<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Questions - ReadWise</title>
  <link rel="stylesheet" href="../stylesheets/shared.css?v=20260316b">
  <script src="../runtime-config.js?v=20260316c"></script>
</head>
<body>
<div class="demo-banner">ReadWise System | Pulo National High School</div>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-mark">RW</div>
      <h2>ReadWise</h2>
      <p>Student Portal</p>
    </div>
    <nav>
      <a href="student-profile.html"><span class="icon" data-icon="profile"></span><span class="nav-label">My Profile</span></a>
      <a href="student-dashboard.html"><span class="icon" data-icon="dashboard"></span><span class="nav-label">Dashboard</span></a>
      <a href="student-passage.html" class="active"><span class="icon" data-icon="passage"></span><span class="nav-label">My Passage</span></a>
      <a href="student-progress.html"><span class="icon" data-icon="progress"></span><span class="nav-label">My Progress</span></a>
      <a href="student-pre-assessment.html"><span class="icon" data-icon="assessment"></span><span class="nav-label">Pre-Assessment</span></a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-info"><strong id="sb-name">-</strong>Grade 7</div>
      <button class="logout-btn" onclick="logout()"><span class="icon" data-icon="logout"></span><span class="nav-label">Logout</span></button>
    </div>
  </aside>
  <main class="main">
    <div class="assessment-shell">
      <button class="back-btn" id="back-lock-btn" type="button" disabled><span class="icon" data-icon="back"></span>Passage Locked After Reading</button>
      <div class="page-header">
        <p class="eyebrow">Comprehension check</p>
        <h1 id="q-title">Comprehension Questions</h1>
        <p id="q-sub"></p>
      </div>
      <div id="questions-wrap"></div>

      <div class="card" id="sa-card" style="margin-top:16px;display:none">
        <div class="section-title">Short Answer</div>
        <p id="sa-prompt" class="question-prompt"></p>
        <textarea class="form-control" id="short-answer" rows="5" placeholder="Write your answer here in complete sentences..."></textarea>
        <p class="micro-copy" style="margin-top:6px">This response will be reviewed and scored by your teacher.</p>
      </div>

      <div class="submission-actions">
        <button class="btn btn-primary" id="submit-btn" onclick="submitAnswers()">Submit Answers</button>
      </div>
    </div>
  </main>
</div>
<div class="toast" id="toast"></div>
<script src="../api.js?v=20260316c"></script>
<script src="../mockData.js?v=20260316b"></script>
<script>
  const params = new URLSearchParams(location.search);
  const pid = params.get("id") || "p3";
  const activeWeek = ReadWiseAPI.getActiveWeek();
  let p = null;
  let s = null;
  let qs = [];
  let shortAnswerPrompt = "";

  const wrap = document.getElementById("questions-wrap");

  async function bootstrapPage() {
    try {
      const cachedUser = ReadWiseAPI.getCachedUser();
      const auth = cachedUser ? { user: cachedUser, cached: true } : await ReadWiseAPI.me();
      if (!auth || !auth.user || auth.user.role !== "student" || !auth.user.student) {
        throw new Error("Unauthorized");
      }
      s = auth.user.student;
      document.getElementById("sb-name").textContent = s.name || "Student";

      p = await ReadWiseAPI.getPassage(pid);
      const assessment = p.assessment || { questions: [], shortAnswerPrompt: "" };
      qs = (assessment.questions || []).map(function(q) { return normalizeAssessmentQuestion(q); });
      shortAnswerPrompt = assessment.shortAnswerPrompt || "";
      const backButton = document.getElementById("back-lock-btn");
      if (backButton) {
        backButton.title = "Back navigation is disabled once reading is completed.";
      }

      if (!p) {
        document.getElementById("q-title").textContent = "Passage not found";
        document.getElementById("q-sub").textContent = "Please go back to your dashboard.";
        document.getElementById("submit-btn").disabled = true;
        document.getElementById("questions-wrap").innerHTML =
          '<div class="card"><div class="surface-note surface-note-danger">No passage data was found for this assessment.</div></div>';
        return;
      }

      document.getElementById("q-title").textContent = "Questions: " + p.title;
      document.getElementById("q-sub").textContent = getClassDisplayName(p.label) + " | " + p.genre + " | " + p.words + " words";

      if (shortAnswerPrompt) {
        document.getElementById("sa-card").style.display = "block";
        document.getElementById("sa-prompt").textContent = shortAnswerPrompt;
      }

      renderQuestions();
    } catch (error) {
      window.location.href = "../login.html";
    }
  }

  function normalizeText(value) {
    return String(value || "").toLowerCase().trim().replace(/\s+/g, " ");
  }

  function parseCommaList(value) {
    return String(value || "")
      .split(",")
      .map(function(item) { return normalizeText(item); })
      .filter(function(item) { return item; });
  }

  function getQuestionInstruction(question) {
    if (question.type === "multiple_choice" || question.type === "multiple_choice_harder") {
      return "Choose the one best answer from the four choices.";
    }
    if (question.type === "true_false") {
      return "Read the statement carefully, then choose True or False.";
    }
    if (question.type === "true_false_modified") {
      return "Choose True or False. If you choose False, you must type the corrected answer.";
    }
    if (question.type === "sequence") {
      return "Type the steps in the correct order, separated by commas.";
    }
    if (question.type === "fill_in_the_blanks") {
      return "Type the missing word or phrase from the passage.";
    }
    if (question.type === "identification") {
      return "Type the exact word, term, or phrase asked in the question.";
    }
    if (question.type === "enumeration") {
      return "List the required answers separated by commas.";
    }
    return "Read the question carefully and type your answer in the field below.";
  }

  function renderQuestionInstruction(question, card) {
    const instruction = document.createElement("p");
    instruction.className = "micro-copy";
    instruction.style.marginBottom = "12px";
    instruction.textContent = getQuestionInstruction(question);
    card.appendChild(instruction);
  }

  function renderNoQuestionsState() {
    wrap.innerHTML =
      '<div class="card">' +
      '<h3 class="passage-list-title" style="margin-bottom:8px">No assessment questions yet</h3>' +
      '<p class="muted-copy">Your teacher has not added questions for this passage yet.</p>' +
      "</div>";
  }

  function renderMCQ(question, index, card) {
    const options = Array.isArray(question.options) ? question.options.filter(Boolean) : [];
    const optWrap = document.createElement("div");
    optWrap.className = "question-options";
    options.forEach(function(opt, optionIndex) {
      const lbl = document.createElement("label");
      lbl.className = "question-option";
      const radio = document.createElement("input");
      radio.type = "radio";
      radio.name = "q" + index;
      radio.value = String(optionIndex);
      radio.style.accentColor = "var(--primary)";
      const span = document.createElement("span");
      span.textContent = String.fromCharCode(65 + optionIndex) + ". " + opt;
      lbl.appendChild(radio);
      lbl.appendChild(span);
      optWrap.appendChild(lbl);
    });
    card.appendChild(optWrap);
  }

  function renderTrueFalse(index, question, card) {
    const optWrap = document.createElement("div");
    optWrap.className = "question-options";
    ["true", "false"].forEach(function(value) {
      const lbl = document.createElement("label");
      lbl.className = "question-option";
      const radio = document.createElement("input");
      radio.type = "radio";
      radio.name = "q" + index;
      radio.value = value;
      radio.style.accentColor = "var(--primary)";
      radio.addEventListener("change", function() {
        const followUp = document.getElementById("q_tf_follow_" + index);
        if (!followUp) return;
        followUp.style.display = question.type === "true_false_modified" && value === "false" ? "block" : "none";
      });
      const span = document.createElement("span");
      span.textContent = value === "true" ? "True" : "False";
      lbl.appendChild(radio);
      lbl.appendChild(span);
      optWrap.appendChild(lbl);
    });
    card.appendChild(optWrap);

    if (question.type === "true_false_modified") {
      const followUp = document.createElement("div");
      followUp.id = "q_tf_follow_" + index;
      followUp.style.display = "none";
      followUp.style.marginTop = "12px";

      const followLabel = document.createElement("label");
      followLabel.className = "form-label";
      followLabel.setAttribute("for", "q_tf_correction_" + index);
      followLabel.textContent = "Correct Answer If False";
      followUp.appendChild(followLabel);

      const input = document.createElement("textarea");
      input.className = "form-control";
      input.id = "q_tf_correction_" + index;
      input.rows = 3;
      input.placeholder = "Type the corrected answer or statement here.";
      followUp.appendChild(input);

      const helper = document.createElement("p");
      helper.className = "micro-copy";
      helper.style.marginTop = "6px";
      helper.textContent = "This field is required only when you choose False.";
      followUp.appendChild(helper);
      card.appendChild(followUp);
    }
  }

  function addTextInput(card, id, placeholder, rows) {
    if (rows && rows > 1) {
      const textarea = document.createElement("textarea");
      textarea.className = "form-control";
      textarea.rows = rows;
      textarea.id = id;
      textarea.placeholder = placeholder;
      card.appendChild(textarea);
      return;
    }
    const input = document.createElement("input");
    input.className = "form-control";
    input.type = "text";
    input.id = id;
    input.placeholder = placeholder;
    card.appendChild(input);
  }

  function renderQuestions() {
    wrap.innerHTML = "";
    if (!qs.length) {
      renderNoQuestionsState();
      return;
    }

    const introCard = document.createElement("div");
    introCard.className = "card";
    introCard.innerHTML =
      '<div class="surface-note surface-note-accent">' +
      'Passage locked. You are now in the question section and cannot return to the passage while answering.' +
      "</div>";
    wrap.appendChild(introCard);

    qs.forEach(function(question, index) {
      const card = document.createElement("div");
      card.className = "card question-card";

      const qText = document.createElement("div");
      qText.className = "question-prompt";
      qText.textContent = "Q" + (index + 1) + ". " + question.prompt;
      card.appendChild(qText);
      renderQuestionInstruction(question, card);

      if (question.type === "multiple_choice" || question.type === "multiple_choice_harder") {
        renderMCQ(question, index, card);
      } else if (question.type === "true_false" || question.type === "true_false_modified") {
        renderTrueFalse(index, question, card);
      } else if (question.type === "sequence") {
        addTextInput(card, "q_text_" + index, "Enter the sequence in order, separated by commas.", 2);
      } else if (question.type === "fill_in_the_blanks" || question.type === "identification") {
        addTextInput(card, "q_text_" + index, "Type your answer", 1);
      } else if (question.type === "enumeration") {
        addTextInput(card, "q_text_" + index, "List your answers separated by commas.", 3);
      } else {
        addTextInput(card, "q_text_" + index, "Type your custom response.", 3);
      }

      wrap.appendChild(card);
    });
  }

  function getResponse(index, question) {
    if (question.type === "true_false_modified") {
      const selected = document.querySelector('input[name="q' + index + '"]:checked');
      const correction = document.getElementById("q_tf_correction_" + index);
      return {
        choice: selected ? selected.value : "",
        correction: correction ? correction.value.trim() : ""
      };
    }
    if (question.type === "multiple_choice" || question.type === "multiple_choice_harder" || question.type === "true_false") {
      const selected = document.querySelector('input[name="q' + index + '"]:checked');
      return selected ? selected.value : "";
    }
    const textInput = document.getElementById("q_text_" + index);
    return textInput ? textInput.value.trim() : "";
  }

  function isResponseProvided(question, response) {
    if (question.type === "true_false_modified") {
      if (!response || !response.choice) return false;
      if (normalizeText(response.choice) === "false") {
        return Boolean(String(response.correction || "").trim());
      }
      return true;
    }
    if (question.type === "multiple_choice" || question.type === "multiple_choice_harder" || question.type === "true_false") {
      return response !== "";
    }
    return Boolean(String(response || "").trim());
  }

  function evaluateResponse(question, response) {
    if (question.type === "multiple_choice" || question.type === "multiple_choice_harder") {
      const ok = Number(response) === Number(question.answerIndex);
      return { earned: ok ? 1 : 0, possible: 1, correct: ok };
    }

    if (question.type === "true_false") {
      const ok = normalizeText(response) === normalizeText(question.answerKey);
      return { earned: ok ? 1 : 0, possible: 1, correct: ok };
    }

    if (question.type === "true_false_modified") {
      const choice = response && typeof response === "object" ? response.choice : "";
      const correction = response && typeof response === "object" ? response.correction : "";
      const choiceCorrect = normalizeText(choice) === normalizeText(question.answerKey);
      if (!choiceCorrect) {
        return { earned: 0, possible: 1, correct: false };
      }
      if (normalizeText(question.answerKey) === "false") {
        const accepted = (question.answerKeys || []).map(normalizeText).filter(Boolean);
        const correctionOk = accepted.length
          ? accepted.includes(normalizeText(correction))
          : Boolean(normalizeText(correction));
        return { earned: correctionOk ? 1 : 0, possible: 1, correct: correctionOk };
      }
      return { earned: 1, possible: 1, correct: true };
    }

    if (question.type === "sequence") {
      const expected = (question.answerKeys || []).map(normalizeText).filter(Boolean);
      const actual = parseCommaList(response);
      const ok = expected.length > 0 &&
        expected.length === actual.length &&
        expected.every(function(item, i) { return item === actual[i]; });
      return { earned: ok ? 1 : 0, possible: 1, correct: ok };
    }

    if (question.type === "enumeration") {
      const expected = (question.answerKeys || []).map(normalizeText).filter(Boolean);
      const actual = parseCommaList(response);
      if (!expected.length) return { earned: 0, possible: 1, correct: false };
      const matched = expected.filter(function(item) { return actual.includes(item); }).length;
      const perfect = matched === expected.length;
      return { earned: matched, possible: expected.length, correct: perfect };
    }

    const accepted = (question.answerKeys || []).map(normalizeText).filter(Boolean);
    const ok = accepted.includes(normalizeText(response));
    return { earned: ok ? 1 : 0, possible: 1, correct: ok };
  }

  async function submitAnswers() {
    if (!p) {
      showToast("No passage loaded for this session.", "#c0392b");
      return;
    }
    if (!qs.length) {
      showToast("No assessment questions are available yet.", "#c0392b");
      return;
    }

    let totalEarned = 0;
    let totalPossible = 0;
    let fullyCorrect = 0;
    const responses = [];

    const unanswered = qs.some(function(question, index) {
      return !isResponseProvided(question, getResponse(index, question));
    });
    if (unanswered) {
      showToast("Please complete every question before submitting.", "#c0392b");
      return;
    }

    qs.forEach(function(question, index) {
      const response = getResponse(index, question);
      const result = evaluateResponse(question, response);
      totalEarned += result.earned;
      totalPossible += result.possible;
      if (result.correct) fullyCorrect++;
      responses.push({ type: question.type, value: response, earned: result.earned, possible: result.possible });
    });

    const pct = totalPossible ? Math.round((totalEarned / totalPossible) * 100) : 0;
    const sa = document.getElementById("short-answer");
    const saVal = sa ? sa.value.trim() : "";
    const underReview = Boolean(shortAnswerPrompt);

    if (underReview && !saVal) {
      showToast("Please complete the short answer for teacher review.", "#c0392b");
      return;
    }

    sessionStorage.setItem("result_" + pid, JSON.stringify({
      score: pct,
      correct: fullyCorrect,
      total: qs.length,
      week: activeWeek,
      passageId: pid,
      shortAnswer: saVal,
      underReview: underReview,
      responses: responses,
      readingTime: sessionStorage.getItem("readingTime_" + pid) || "-"
    }));

    try {
      await ReadWiseAPI.submitStudentAttempt({
        week: activeWeek,
        passageId: pid,
        score: pct,
        correct: fullyCorrect,
        total: qs.length,
        shortAnswer: saVal,
        responses: responses,
        readingTime: sessionStorage.getItem("readingTime_" + pid) || "-"
      });
    } catch (error) {
      showToast(error.message || "Unable to submit to server.", "#c0392b");
      return;
    }

    showToast("Answers submitted successfully.");
    setTimeout(function() {
      window.location.href = "student-results.html?id=" + pid;
    }, 900);
  }

  async function logout() {
    try {
      await ReadWiseAPI.logout();
    } catch (error) {
      // ignore logout API errors
    }
    sessionStorage.clear();
    window.location.href = "../login.html";
  }

  bootstrapPage();
</script>
</body>
</html>
